{
	"name": "portfolio-website",
	"version": "2.0.0",
	"type": "module",
	"homepage": "https://pauldiloreto.com",
	"private": true,
	"author": "Paul DiLoreto <soodohh@pm.me>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/soodoh/portfolio-website/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/soodoh/portfolio-website.git"
	},
	"keywords": [
		"portfolio",
		"developer",
		"engineer",
		"tanstack",
		"react",
		"aws-amplify",
		"static-site"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && bun scripts/finalize-static-output.mjs",
		"start": "bun scripts/serve-static.mjs",
		"test:e2e": "./scripts/playwright-docker.sh",
		"test:e2e:update": "./scripts/playwright-docker.sh --update-snapshots",
		"test:e2e:container": "playwright test",
		"test:e2e:local": "playwright test",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.tools.json",
		"prepare": "lefthook install",
		"preview": "bun scripts/serve-static.mjs",
		"test:static": "bun scripts/assert-static-output.mjs",
		"test:hosting": "bun scripts/hosting-smoke.mjs",
		"test:e2e:static": "bun run build && bun run test:e2e:static:prebuilt",
		"test:e2e:static:prebuilt": "PLAYWRIGHT_STATIC=1 PLAYWRIGHT_EXPECT_STATIC_404=1 ./scripts/playwright-docker.sh",
		"lighthouse": "lhci autorun"
	},
	"dependencies": {
		"@fontsource/fjalla-one": "^5.3.0",
		"@fontsource/geo": "^5.3.0",
		"@tailwindcss/vite": "^4.3.3",
		"@tanstack/react-router": "^1.170.18",
		"@tanstack/react-start": "^1.168.32",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.26.0",
		"radix-ui": "^1.6.5",
		"react": "^19.2.8",
		"react-dom": "^19.2.8",
		"react-scroll-parallax": "^3.5.0",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.5",
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@commitlint/types": "^21.2.0",
		"@lhci/cli": "^0.15.1",
		"@playwright/test": "^1.61.1",
		"@types/node": "26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.4",
		"lefthook": "^2.1.10",
		"shadcn": "^4.14.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^7.0.2",
		"vite": "^8.1.5"
	},
	"packageManager": "bun@1.3.14",
	"engines": {
		"bun": "1.3.14"
	}
}
