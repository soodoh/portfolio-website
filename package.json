{
	"name": "portfolio-website",
	"version": "2.0.0",
	"type": "module",
	"homepage": "https://pauldiloreto.com",
	"private": true,
	"author": "Paul DiLoreto <soodohh@pm.me>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/soodoh/portfolio-website/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/soodoh/portfolio-website.git"
	},
	"keywords": [
		"portfolio",
		"developer",
		"engineer",
		"tanstack",
		"react",
		"aws-amplify",
		"static-site"
	],
	"trustedDependencies": [
		"puppeteer",
		"sharp",
		"unrs-resolver"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && bun scripts/finalize-static-output.mjs",
		"start": "bun scripts/serve-static.mjs",
		"test:e2e": "./scripts/playwright-docker.sh",
		"test:e2e:update": "./scripts/playwright-docker.sh --update-snapshots",
		"test:e2e:container": "playwright test",
		"test:e2e:local": "playwright test",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"prepare": "lefthook install",
		"preview": "bun scripts/serve-static.mjs",
		"test:static": "bun scripts/assert-static-output.mjs",
		"test:hosting": "bun scripts/hosting-smoke.mjs",
		"test:e2e:static": "PLAYWRIGHT_STATIC=1 ./scripts/playwright-docker.sh",
		"lighthouse": "lhci autorun"
	},
	"dependencies": {
		"@fontsource/fjalla-one": "^5.2.7",
		"@fontsource/geo": "^5.2.7",
		"@tailwindcss/vite": "^4.3.2",
		"@tanstack/react-router": "^1.170.17",
		"@tanstack/react-start": "^1.168.27",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.24.0",
		"radix-ui": "^1.6.2",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-scroll-parallax": "^3.5.0",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@commitlint/types": "^21.2.0",
		"@contentful/rich-text-types": "^17.2.7",
		"@lhci/cli": "^0.15.1",
		"@playwright/test": "^1.61.1",
		"@types/node": "26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"find-up": "^7.0.0",
		"lefthook": "^2.1.10",
		"shadcn": "^4.13.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^8.1.4"
	},
	"packageManager": "bun@1.3.13",
	"engines": {
		"bun": "1.3.13"
	}
}
